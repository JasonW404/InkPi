# InkPi Secrets Configuration
# Copy this file to .env and fill in your actual values.
# Non-secret configuration (username, location, display policy, etc.)
# belongs in ~/.config/inkpi/config.json — see inkpi/config.py for defaults.

# GitHub Personal Access Token (for private repo data)
# Create at: https://github.com/settings/tokens
# Scopes needed: repo
EINK_GITHUB_API_KEY=github_pat_xxxxxxxxxxxxx

# Weather API Key (optional, Open-Meteo is free without a key)
EINK_WEATHER_API_KEY=
