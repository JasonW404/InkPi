# eInk Dashboard Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================
# GitHub Configuration
# ============================================
# Your GitHub username (required for contribution stats)
EINK_GITHUB_USERNAME=YourGitHubUsername

# Your GitHub organization name (required for org stats)
EINK_GITHUB_ORG=YourOrgName

# GitHub Personal Access Token (optional, for private repo data)
# Create at: https://github.com/settings/tokens
# Scopes needed: repo (for private repos)
EINK_GITHUB_API_KEY=github_pat_xxxxxxxxxxxxx

# ============================================
# Weather Configuration
# ============================================
# Location can be:
# - Place name: "上海", "Shanghai", "Beijing", "Paris, France"
# - Coordinates: "31.2304,121.4737" (latitude,longitude)
EINK_WEATHER_LOCATION=上海

# Timezone for datetime display (default: UTC)
# Examples: UTC, Asia/Shanghai, America/New_York, Europe/Paris
EINK_TIMEZONE=Asia/Shanghai

# ============================================
# Knowledge Cards Configuration
# ============================================
# Local JSON file path for knowledge cards
EINK_KNOWLEDGE_LOCAL_FILE=data/cards.json

# Enable remote knowledge cards (0 or 1)
EINK_KNOWLEDGE_REMOTE_ENABLED=0

# Remote URL for fetching knowledge cards (if enabled)
EINK_KNOWLEDGE_REMOTE_URL=https://example.com/cards.json

# ============================================
# Display Refresh Configuration
# ============================================
# Partial refresh interval in seconds (default: 60)
EINK_PARTIAL_REFRESH_INTERVAL_SECONDS=60

# Full refresh interval in seconds (default: 3600 = 1 hour)
EINK_FULL_REFRESH_INTERVAL_SECONDS=3600

# Maximum partial refreshes before forcing full refresh (default: 30)
EINK_MAX_PARTIAL_REFRESHES_BEFORE_FULL=30

# ============================================
# Screen Configuration (Advanced)
# ============================================
# Screen dimensions (default: 800x480 for Waveshare 4.26")
EINK_SCREEN_WIDTH=800
EINK_SCREEN_HEIGHT=480

# Grayscale levels (default: 4)
EINK_GRAYSCALE_LEVELS=4

# Orientation (default: landscape)
EINK_ORIENTATION=landscape
